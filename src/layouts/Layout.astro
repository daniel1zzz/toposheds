---
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en" class="bg-neutral-950 text-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Custom sheds and home renovations. Reliable craftsmanship built for your space."
    />
    <meta
      name="keywords"
      content="TOPO, Sheds, Remodeling, Construction, Home, Design"
    />
    <meta name="author" content="TOPO Sheds & Remodeling LLC" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/TOPO_Sheds_Remodeling_logo.svg"
    />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Montserrat:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      @import "tailwindcss";
      body {
        font-family: "Inter", sans-serif;
      }
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: "Montserrat", sans-serif;
      }
    </style>
  </head>
  <body class="antialiased">
    <main class="py-24 px-6 max-w-6xl mx-auto">
      <slot />
    </main>
  </body>
  <Footer />
</html>
